{
  "name": "ai-native-company-brain",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, self-hostable company brain with governed memory, registry, cron, and MCP-compatible agent surfaces.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "ci": "npm run typecheck && npm test && npm run build",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:migrate:dry-run": "tsx scripts/db-migrate.ts --dry-run",
    "db:seed": "tsx scripts/db-seed.ts",
    "db:seed:dry-run": "tsx scripts/db-seed.ts --dry-run",
    "issue:checkpoint": "node scripts/linear-issue-loop.mjs checkpoint",
    "issue:finish": "node scripts/linear-issue-loop.mjs finish",
    "issue:pick": "node scripts/linear-issue-loop.mjs pick",
    "issue:verify": "node scripts/linear-issue-loop.mjs verify",
    "mcp:smoke": "tsx scripts/mcp-smoke-test.ts",
    "start": "next start",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "render:architecture": "sips -s format png docs/assets/ai-native-company-brain-architecture.svg --out docs/assets/ai-native-company-brain-architecture.png || magick docs/assets/ai-native-company-brain-architecture.svg docs/assets/ai-native-company-brain-architecture.png"
  },
  "dependencies": {
    "@types/node": "^24.0.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "lucide-react": "^0.523.0",
    "next": "^15.3.4",
    "pg": "^8.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "zod": "^3.25.67"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "vitest": "^3.2.6"
  }
}
